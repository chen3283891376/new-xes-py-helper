{
	"name": "new-xes-py-helper",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun index.ts",
		"build": "bun build ./index.ts --compile --bytecode --outfile helper --production --minify-whitespace --minify-syntax --minify-identifiers",
